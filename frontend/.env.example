# Frontend environment variables
# Replace with your deployment URLs.

# API base URL for frontend requests such as /api/auth, /api/productos, etc.
VITE_API_URL=https://tu-backend.example.com/api

# Upload server URL for local upload service endpoints.
# If your backend serves uploads from the same host, this can be the backend base URL.
VITE_UPLOADS_URL=https://tu-backend.example.com
