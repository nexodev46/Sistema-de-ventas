{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3001",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Task Core Sales",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "windows": [
      {
        "title": "Task Core Sales",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.taskcoresales.app",
      "icon": [
        "icons/32x32.png",
        "icons/icon.icns"
      ]
    }
  }
}
