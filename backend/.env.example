# Backend uploads service environment variables
# Use these values in production, for example with Render o cualquier otro host.

# Puerto en el que se ejecuta el backend (opcional, usa 4000 si no se define).
PORT=4000

# Permitir peticiones desde el frontend desplegado.
FRONTEND_ORIGIN=https://tu-frontend.example.com

# Firebase Admin - en producción debe proporcionar credenciales seguras.
# FIREBASE_SERVICE_ACCOUNT debe ser el JSON completo del service account como string.
# Alternativamente, configure GOOGLE_APPLICATION_CREDENTIALS en el entorno del host.
FIREBASE_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Stripe secret key (obligatorio para pagos reales).
STRIPE_SECRET_KEY=sk_live_xxx

# SMTP para envíos de email de soporte.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-app
SUPPORT_EMAIL=soporte@tu-empresa.com
