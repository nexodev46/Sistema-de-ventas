# ============================================
# ARCHIVO DE EJEMPLO - COPIAR A .env
# ============================================
# Este archivo muestra qué variables necesitas configurar
# Nunca commities el archivo .env real a git

# Puerto del servidor
PORT=4000

# URL del frontend
FRONTEND_ORIGIN=http://localhost:3000

# Firebase (obtén esto de tu consola Firebase)
FIREBASE_API_KEY=tu_api_key_aqui
FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu_proyecto_id
FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
FIREBASE_APP_ID=tu_app_id

# Stripe (obtén en https://stripe.com)
STRIPE_SECRET_KEY=sk_test_tu_key_aqui
STRIPE_WEBHOOK_SECRET=whsec_tu_secret_aqui

# Email SMTP (Gmail, SendGrid, etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
SUPPORT_EMAIL=soporte@tu-empresa.com

# Sentry (obtén en https://sentry.io)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Configuración de uploads
MAX_FILE_SIZE=5242880
UPLOAD_LIMITER_MAX=20

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Seguridad
NODE_ENV=production
